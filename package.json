{
  "name": "howdz-online-cad",
  "version": "0.1.0",
  "description": "纯前端在线CAD插件 - 支持二维图形绘制和DXF文件导入导出",
  "type": "module",
  "main": "./dist/howdz-online-cad.umd.cjs",
  "module": "./dist/howdz-online-cad.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/howdz-online-cad.js",
      "require": "./dist/howdz-online-cad.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:demo": "tsc && cross-env BUILD_MODE=demo vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "cad",
    "canvas",
    "dxf",
    "2d",
    "drawing",
    "frontend"
  ],
  "author": "howdz",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
